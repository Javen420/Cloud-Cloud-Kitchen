{
    "swagger": "2.0",
    "info": {
        "description": "Calculates delivery ETA using Google Routes or haversine fallback",
        "title": "ETA Calculation Service",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8088",
    "basePath": "/",
    "paths": {
        "/api/v1/eta/calculate": {
            "get": {
                "description": "Returns estimated time and distance from driver to dropoff using Google Routes API, falling back to haversine",
                "tags": [
                    "eta"
                ],
                "summary": "Calculate delivery ETA",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Order ID",
                        "name": "order_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Driver ID",
                        "name": "driver_id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Driver latitude",
                        "name": "driver_lat",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Driver longitude",
                        "name": "driver_lng",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Dropoff latitude",
                        "name": "dropoff_lat",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Dropoff longitude",
                        "name": "dropoff_lng",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handler.ETAResult"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns service health status",
                "tags": [
                    "health"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.ETAResult": {
            "type": "object",
            "properties": {
                "calculated_at": {
                    "type": "string"
                },
                "distance_meters": {
                    "type": "integer"
                },
                "driver_id": {
                    "type": "string"
                },
                "estimated_minutes": {
                    "type": "integer"
                },
                "order_id": {
                    "type": "string"
                },
                "source": {
                    "type": "string"
                }
            }
        }
    }
}